{
  "benchmark_version": "1.0",
  "benchmark_id": "logicpearl_guardrails_v1",
  "description": "Public LogicPearl benchmark manifest for guardrail development and proof.",
  "task": "prompt_injection_and_guardrail_routing",
  "recommended_pipeline": {
    "observer_stage": "extract normalized security and routing features from raw requests, tool plans, documents, or web content",
    "policy_stages": [
      "tool_authorization",
      "injection_boundary",
      "data_exfiltration",
      "route_status"
    ],
    "final_routes": [
      "allow",
      "deny",
      "needs_human_review"
    ]
  },
  "splits": {
    "train": {
      "purpose": "Build and calibrate observers, pearls, and routing policy.",
      "groups": [
        {
          "id": "prompt_injection",
          "datasets": [
            {
              "name": "Salad-Data base_set",
              "type": "prompt_injection",
              "role": "broad prompt-injection corpus"
            },
            {
              "name": "Salad-Data attack_enhanced_set",
              "type": "prompt_injection",
              "role": "attack-enhanced prompt-injection corpus"
            },
            {
              "name": "ChatGPT-Jailbreak-Prompts",
              "type": "prompt_injection",
              "role": "small jailbreak set"
            },
            {
              "name": "OpenAgentSafety S26",
              "type": "prompt_injection",
              "role": "agent-safety prompt set"
            },
            {
              "name": "MCPMark",
              "type": "prompt_injection",
              "role": "tool and agent-task pressure set"
            },
            {
              "name": "SafeArena safe",
              "type": "negative",
              "role": "benign agent-task control set"
            },
            {
              "name": "SafeArena harm",
              "type": "prompt_injection",
              "role": "harmful prompt pressure set"
            },
            {
              "name": "Vigil",
              "type": "prompt_injection",
              "role": "scanner-oriented jailbreak examples"
            },
            {
              "name": "ALERT",
              "type": "prompt_injection",
              "role": "large harmful-instruction pressure set"
            },
            {
              "name": "ALERT_Adv",
              "type": "prompt_injection",
              "role": "adversarial alert variant"
            }
          ]
        },
        {
          "id": "moderation",
          "datasets": [
            {
              "name": "NOETI ToxicQAFinal",
              "type": "content_moderation",
              "role": "harmful-content routing pressure"
            }
          ]
        },
        {
          "id": "benign_negative",
          "datasets": [
            {
              "name": "SQuAD 2.0",
              "type": "negative",
              "role": "false-positive control set"
            }
          ]
        }
      ]
    },
    "dev": {
      "purpose": "Held-out tuning split for thresholds, overblocking, and route quality.",
      "groups": [
        {
          "id": "prompt_injection",
          "source": "held-out slices from the public development corpora"
        },
        {
          "id": "moderation",
          "source": "held-out moderation slice"
        },
        {
          "id": "benign_negative",
          "source": "held-out benign slice, ideally including agent/tool-use tasks"
        }
      ]
    },
    "external_checks": {
      "purpose": "Open post-freeze checks kept separate from development and tuning.",
      "groups": [
        {
          "id": "open_external_benchmarks",
          "datasets": [
            {
              "name": "JailbreakBench",
              "type": "prompt_injection",
              "role": "post_freeze_external_check"
            },
            {
              "name": "PromptShield",
              "type": "prompt_injection",
              "role": "post_freeze_external_check"
            },
            {
              "name": "rogue-security/prompt-injections-benchmark",
              "type": "prompt_injection",
              "role": "post_freeze_external_check"
            }
          ]
        }
      ]
    }
  },
  "metrics": [
    "attack_catch_rate",
    "false_positive_rate",
    "benign_pass_rate",
    "review_rate",
    "observer_extraction_success_rate",
    "deterministic_route_coverage"
  ],
  "rules": [
    "Do not tune on proof data.",
    "Do not report a single score without false-positive context.",
    "Prefer category-level reporting over one aggregate number.",
    "Keep public benchmark results separate from internal customer evaluations."
  ]
}
