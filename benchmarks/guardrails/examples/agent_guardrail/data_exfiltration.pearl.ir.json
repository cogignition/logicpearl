{
  "ir_version": "1.0",
  "gate_id": "data_exfiltration",
  "gate_type": "bitmask_gate",
  "input_schema": {
    "features": [
      {
        "id": "requests_secret_exfiltration",
        "type": "bool"
      },
      {
        "id": "requests_data_access_outside_scope",
        "type": "bool"
      }
    ]
  },
  "rules": [
    {
      "id": "deny_secret_exfiltration",
      "kind": "predicate",
      "bit": 0,
      "deny_when": {
        "feature": "requests_secret_exfiltration",
        "op": "==",
        "value": true
      },
      "message": "Secret and credential extraction is blocked."
    },
    {
      "id": "deny_bulk_data_exfiltration",
      "kind": "predicate",
      "bit": 1,
      "deny_when": {
        "feature": "requests_data_access_outside_scope",
        "op": "==",
        "value": true
      },
      "message": "Bulk data movement outside trusted scope is blocked."
    }
  ],
  "evaluation": {
    "combine": "bitwise_or",
    "allow_when_bitmask": 0
  },
  "verification": {
    "correctness_scope": "Example agent guardrail policy artifact."
  },
  "provenance": {
    "generator": "logicpearl.guardrail_example",
    "generator_version": "0.1.0"
  }
}
