{
  "pipeline_version": "1.0",
  "pipeline_id": "observer_membership_pipeline",
  "entrypoint": "input",
  "stages": [
    {
      "id": "observer",
      "kind": "observer_plugin",
      "plugin_manifest": "plugins/python_observer/manifest.json",
      "input": {
        "age": "$.age",
        "member": "$.member",
        "country": "$.country"
      },
      "export": {
        "age": "$.features.age",
        "is_member": "$.features.is_member"
      }
    },
    {
      "id": "gate",
      "kind": "pearl",
      "artifact": "artifacts/membership-demo-v1.json",
      "input": {
        "age": "@observer.age",
        "is_member": "@observer.is_member"
      },
      "export": {
        "bitmask": "$.bitmask",
        "allow": "$.allow"
      }
    }
  ],
  "output": {
    "bitmask": "@gate.bitmask",
    "allow": "@gate.allow"
  }
}
