{
  "pipeline_version": "1.0",
  "pipeline_id": "authz_pipeline",
  "entrypoint": "input",
  "stages": [
    {
      "id": "authz",
      "kind": "pearl",
      "artifact": "../../../fixtures/ir/valid/auth-demo-v1.json",
      "input": {
        "member_age": "$.member.age",
        "requested_amount": "$.request.amount"
      },
      "export": {
        "bitmask": "$.bitmask",
        "allow": "$.allow"
      }
    },
    {
      "id": "audit",
      "kind": "verify_plugin",
      "plugin_manifest": "../../plugins/python_verify/manifest.json",
      "input": {
        "bitmask": "@authz.bitmask"
      },
      "export": {
        "verification_status": "$.verification_status"
      }
    }
  ],
  "output": {
    "bitmask": "@authz.bitmask",
    "allow": "@authz.allow",
    "verification_status": "@audit.verification_status"
  }
}
