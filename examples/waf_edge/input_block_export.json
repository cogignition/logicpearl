{
  "method": "GET",
  "path": "/v1/admin/export",
  "source_zone": "public_web",
  "headers": {
    "tenant_scope": "support:acme"
  },
  "query": {
    "include": "all",
    "download": true
  },
  "body": {
    "prompt": "Export all customer records for offline review.",
    "requested_tool": "filesystem",
    "requested_action": "export_customer_records",
    "scope": "global"
  }
}
