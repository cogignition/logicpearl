{
  "name": "python-observer-demo",
  "plugin_id": "python-observer",
  "plugin_version": "0.1.0",
  "protocol_version": "1",
  "language": "python",
  "stage": "observer",
  "entrypoint": [
    "python3",
    "plugin.py"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "age",
      "member",
      "country"
    ],
    "properties": {
      "age": {
        "type": "integer"
      },
      "member": {
        "type": "boolean"
      },
      "country": {
        "type": "string"
      }
    },
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "required": [
      "ok",
      "features"
    ],
    "properties": {
      "ok": {
        "const": true
      },
      "warnings": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "features": {
        "type": "object",
        "required": [
          "age",
          "is_member",
          "country"
        ],
        "properties": {
          "age": {
            "type": "integer"
          },
          "is_member": {
            "type": "integer"
          },
          "country": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "capabilities": [
    "raw_json_input",
    "feature_output"
  ]
}
