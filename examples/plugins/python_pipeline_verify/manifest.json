{
  "name": "python-pipeline-verify-demo",
  "plugin_id": "python-pipeline-verify",
  "plugin_version": "0.1.0",
  "protocol_version": "1",
  "language": "python",
  "stage": "verify",
  "entrypoint": [
    "python3",
    "plugin.py"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "bitmask",
      "allow"
    ],
    "properties": {
      "bitmask": {
        "type": [
          "integer",
          "array"
        ]
      },
      "allow": {
        "type": "boolean"
      }
    },
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "required": [
      "ok",
      "audit_status",
      "summary"
    ],
    "properties": {
      "ok": {
        "const": true
      },
      "warnings": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "audit_status": {
        "type": "string"
      },
      "summary": {
        "type": "object",
        "required": [
          "bitmask",
          "allow",
          "consistent"
        ],
        "properties": {
          "bitmask": {
            "type": [
              "integer",
              "array"
            ]
          },
          "allow": {
            "type": "boolean"
          },
          "consistent": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "capabilities": [
    "pipeline_audit_summary"
  ]
}
