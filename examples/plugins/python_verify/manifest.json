{
  "name": "python-verify-demo",
  "protocol_version": "1",
  "language": "python",
  "stage": "verify",
  "entrypoint": [
    "python3",
    "plugin.py"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "rules"
    ],
    "properties": {
      "rules": {
        "type": "array"
      }
    }
  },
  "output_schema": {
    "type": "object",
    "required": [
      "ok",
      "rule_statuses",
      "summary"
    ],
    "properties": {
      "ok": {
        "const": true
      },
      "warnings": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "rule_statuses": {
        "type": "array"
      },
      "summary": {
        "type": "object"
      }
    }
  },
  "capabilities": [
    "verification_summary"
  ]
}
