{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logicpearl.com/schema/logicpearl-observation-schema-v1.schema.json",
  "title": "LogicPearl Observation Schema v1",
  "description": "Feature availability contract emitted by upstream observers or extraction plugins before review/build. It is metadata for discovery and review; it does not define policy logic.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "features"],
  "properties": {
    "schema_version": {
      "const": "logicpearl.observation_schema.v1"
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/observedFeature"
      }
    }
  },
  "$defs": {
    "observedFeature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature_id", "type", "operators"],
      "properties": {
        "feature_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["boolean", "integer", "number", "string", "enum"]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "source_anchor": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "nullable": {
          "type": "boolean"
        },
        "operators": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/operator"
          }
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": ["string", "number", "boolean"]
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "enum"
              }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["values"]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "boolean"
              }
            },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "operators": {
                "items": {
                  "enum": ["eq", "in", "is_null"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": ["integer", "number"]
              }
            },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "operators": {
                "items": {
                  "enum": ["eq", "in", "gt", "gte", "lt", "lte", "is_null"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "string"
              }
            },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "operators": {
                "items": {
                  "enum": ["eq", "in", "contains", "startswith", "is_null"]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "enum"
              }
            },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "operators": {
                "items": {
                  "enum": ["eq", "in", "is_null"]
                }
              }
            }
          }
        },
        {
          "if": {
            "not": {
              "properties": {
                "nullable": {
                  "const": true
                }
              },
              "required": ["nullable"]
            }
          },
          "then": {
            "properties": {
              "operators": {
                "not": {
                  "contains": {
                    "const": "is_null"
                  }
                }
              }
            }
          }
        }
      ]
    },
    "operator": {
      "type": "string",
      "enum": ["eq", "in", "gt", "gte", "lt", "lte", "contains", "startswith", "is_null"]
    }
  }
}
