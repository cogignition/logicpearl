{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logicpearl.dev/schema/logicpearl-feature-explanation-v1.schema.json",
  "title": "LogicPearl Feature Explanation v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "feature_id",
    "feature_label",
    "source_id",
    "source_anchor",
    "state_label",
    "state_message",
    "counterfactual_hint"
  ],
  "properties": {
    "feature_id": {
      "type": "string",
      "minLength": 1
    },
    "feature_label": {
      "type": ["string", "null"]
    },
    "source_id": {
      "type": ["string", "null"]
    },
    "source_anchor": {
      "type": ["string", "null"]
    },
    "state_label": {
      "type": ["string", "null"]
    },
    "state_message": {
      "type": ["string", "null"]
    },
    "counterfactual_hint": {
      "type": ["string", "null"]
    }
  }
}
