{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logicpearl.dev/schema/logicpearl-source-manifest-v1.schema.json",
  "title": "LogicPearl Source Manifest v1",
  "type": "object",
  "required": ["schema_version", "sources"],
  "properties": {
    "schema_version": {
      "const": "logicpearl.source_manifest.v1"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_id", "kind", "title", "data_classification"],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "uri": {
            "type": "string",
            "minLength": 1
          },
          "retrieved_at": {
            "type": "string",
            "minLength": 1
          },
          "content_hash": {
            "$ref": "#/$defs/sha256"
          },
          "data_classification": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
