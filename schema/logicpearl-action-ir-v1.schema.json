{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logicpearl.com/schema/logicpearl-action-ir-v1.schema.json",
  "title": "LogicPearl Action IR v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ir_version",
    "action_policy_id",
    "action_policy_type",
    "action_column",
    "default_action",
    "actions",
    "input_schema",
    "rules",
    "evaluation"
  ],
  "properties": {
    "ir_version": {
      "type": "string",
      "const": "1.0"
    },
    "action_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "action_policy_type": {
      "type": "string",
      "const": "priority_rules"
    },
    "action_column": {
      "type": "string",
      "minLength": 1
    },
    "default_action": {
      "type": "string",
      "minLength": 1
    },
    "no_match_action": {
      "type": "string",
      "minLength": 1
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "input_schema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["features"],
      "properties": {
        "features": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/feature"
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/action_rule"
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selection"],
      "properties": {
        "selection": {
          "type": "string",
          "const": "first_match"
        }
      }
    },
    "verification": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "domain_constraints": {
          "type": ["array", "null"],
          "items": {
            "$ref": "#/$defs/comparison"
          }
        },
        "correctness_scope": {
          "type": ["string", "null"]
        }
      }
    },
    "provenance": {
      "type": ["object", "null"],
      "additionalProperties": true,
      "properties": {
        "generator": { "type": ["string", "null"] },
        "generator_version": { "type": ["string", "null"] },
        "source_commit": { "type": ["string", "null"] },
        "created_at": { "type": ["string", "null"] }
      }
    }
  },
  "$defs": {
    "feature": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["bool", "int", "float", "string", "enum"]
        },
        "description": {
          "type": ["string", "null"]
        },
        "values": {
          "type": ["array", "null"],
          "minItems": 1,
          "items": {
            "type": ["string", "number", "integer", "boolean"]
          }
        },
        "min": {
          "type": ["number", "null"]
        },
        "max": {
          "type": ["number", "null"]
        },
        "editable": {
          "type": ["boolean", "null"]
        }
      }
    },
    "action_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "bit", "action", "priority", "when"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "bit": {
          "type": "integer",
          "minimum": 0
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "integer",
          "minimum": 0
        },
        "when": {
          "$ref": "#/$defs/expression"
        },
        "label": {
          "type": ["string", "null"]
        },
        "message": {
          "type": ["string", "null"]
        },
        "severity": {
          "type": ["string", "null"]
        },
        "counterfactual_hint": {
          "type": ["string", "null"]
        },
        "verification_status": {
          "type": ["string", "null"],
          "enum": [
            "solver_verified",
            "pipeline_unverified",
            "heuristic_unverified",
            "refined_unverified",
            null
          ]
        },
        "evidence": {
          "$ref": "#/$defs/rule_evidence"
        }
      }
    },
    "rule_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "support", "reliability"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "logicpearl.rule_evidence.v2"
        },
        "support": {
          "$ref": "#/$defs/rule_support_evidence"
        },
        "reliability": {
          "$ref": "#/$defs/rule_reliability_evidence"
        },
        "simplifications": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rule_simplification_evidence"
          }
        }
      }
    },
    "rule_simplification_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "reason",
        "before_rule_count",
        "after_rule_count",
        "removed_rule_count",
        "training_total_errors_before",
        "training_total_errors_after",
        "validation_total_errors_before",
        "validation_total_errors_after",
        "denied_trace_count_before",
        "denied_trace_count_after",
        "allowed_trace_count_before",
        "allowed_trace_count_after"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "dropped_predicates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "before_rule_count": {
          "type": "integer",
          "minimum": 0
        },
        "after_rule_count": {
          "type": "integer",
          "minimum": 0
        },
        "removed_rule_count": {
          "type": "integer",
          "minimum": 0
        },
        "training_total_errors_before": {
          "type": "integer",
          "minimum": 0
        },
        "training_total_errors_after": {
          "type": "integer",
          "minimum": 0
        },
        "validation_total_errors_before": {
          "type": "integer",
          "minimum": 0
        },
        "validation_total_errors_after": {
          "type": "integer",
          "minimum": 0
        },
        "denied_trace_count_before": {
          "type": "integer",
          "minimum": 0
        },
        "denied_trace_count_after": {
          "type": "integer",
          "minimum": 0
        },
        "allowed_trace_count_before": {
          "type": "integer",
          "minimum": 0
        },
        "allowed_trace_count_after": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "rule_support_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["denied_trace_count", "allowed_trace_count"],
      "properties": {
        "denied_trace_count": {
          "type": "integer",
          "minimum": 0
        },
        "allowed_trace_count": {
          "type": "integer",
          "minimum": 0
        },
        "example_traces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rule_trace_evidence"
          }
        }
      }
    },
    "rule_reliability_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "matched_trace_count",
        "total_denied_examples",
        "total_allowed_examples",
        "precision",
        "recall_contribution",
        "false_positive_rate",
        "lift"
      ],
      "properties": {
        "matched_trace_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_denied_examples": {
          "type": "integer",
          "minimum": 0
        },
        "total_allowed_examples": {
          "type": "integer",
          "minimum": 0
        },
        "precision": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "recall_contribution": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "false_positive_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "lift": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "rule_trace_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_row_hash"],
      "properties": {
        "trace_row_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "source_anchor": {
          "type": "string",
          "minLength": 1
        },
        "citation": {
          "type": "string",
          "minLength": 1
        },
        "quote_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "op", "value"],
      "properties": {
        "feature": {
          "type": "string",
          "minLength": 1
        },
        "op": {
          "type": "string",
          "enum": ["==", "!=", ">", ">=", "<", "<=", "in", "not_in"]
        },
        "value": {}
      }
    },
    "expression": {
      "oneOf": [
        { "$ref": "#/$defs/comparison" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["all"],
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["any"],
          "properties": {
            "any": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["not"],
          "properties": {
            "not": {
              "$ref": "#/$defs/expression"
            }
          }
        }
      ]
    }
  }
}
