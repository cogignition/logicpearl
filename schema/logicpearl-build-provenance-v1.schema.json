{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logicpearl.com/schema/logicpearl-build-provenance-v1.schema.json",
  "title": "LogicPearl Build Provenance v1",
  "type": "object",
  "required": [
    "schema_version",
    "engine_version",
    "build_command",
    "build_options_hash",
    "input_traces",
    "plugins",
    "environment",
    "generated_files"
  ],
  "properties": {
    "schema_version": {
      "const": "logicpearl.build_provenance.v1"
    },
    "engine_version": {
      "type": "string",
      "minLength": 1
    },
    "engine_commit": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "build_command": {
      "type": "object",
      "required": ["program", "args", "redacted"],
      "properties": {
        "program": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "redacted": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "build_options": {
      "type": ["object", "null"]
    },
    "build_options_hash": {
      "$ref": "#/$defs/sha256"
    },
    "input_traces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "hash", "row_count"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "hash": {
            "$ref": "#/$defs/sha256"
          },
          "row_count": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    },
    "feature_dictionary": {
      "$ref": "#/$defs/file_provenance"
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "stage", "manifest_path"],
        "properties": {
          "schema_version": {
            "const": "logicpearl.plugin_run_provenance.v1"
          },
          "plugin_run_id": {
            "$ref": "#/$defs/sha256"
          },
          "plugin_id": {
            "type": "string",
            "minLength": 1
          },
          "plugin_version": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "plugin_name": {
            "type": "string",
            "minLength": 1
          },
          "stage": {
            "$ref": "#/$defs/plugin_stage"
          },
          "protocol_version": {
            "type": "string",
            "minLength": 1
          },
          "manifest_path": {
            "type": "string",
            "minLength": 1
          },
          "manifest_hash": {
            "$ref": "#/$defs/sha256"
          },
          "manifest_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "entrypoint_hash": {
            "$ref": "#/$defs/sha256"
          },
          "entrypoint": {
            "$ref": "#/$defs/plugin_entrypoint"
          },
          "input": {
            "type": "object",
            "required": ["kind", "value"],
            "properties": {
              "kind": {
                "type": "string",
                "minLength": 1
              },
              "value": {
                "type": "string"
              },
              "hash": {
                "$ref": "#/$defs/sha256"
              }
            },
            "additionalProperties": true
          },
          "input_hash": {
            "$ref": "#/$defs/sha256"
          },
          "request_hash": {
            "$ref": "#/$defs/sha256"
          },
          "output_hash": {
            "$ref": "#/$defs/sha256"
          },
          "options": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "rows_emitted": {
            "type": "integer",
            "minimum": 0
          },
          "completed_at": {
            "type": "string",
            "minLength": 1
          },
          "started_at": {
            "type": "string",
            "minLength": 1
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0
          },
          "timeout_policy": {
            "$ref": "#/$defs/timeout_policy"
          },
          "execution_policy": {
            "$ref": "#/$defs/execution_policy"
          },
          "capabilities": {
            "$ref": "#/$defs/capabilities"
          },
          "access": {
            "$ref": "#/$defs/plugin_access"
          },
          "stdio": {
            "$ref": "#/$defs/plugin_stdio"
          }
        },
        "additionalProperties": true
      }
    },
    "observation_runs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/observation_run_provenance"
      }
    },
    "source_manifest": {
      "allOf": [
        { "$ref": "#/$defs/file_provenance" },
        {
          "type": "object",
          "properties": {
            "sources": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/source"
              }
            }
          }
        }
      ]
    },
    "environment": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean", "object", "array", "null"]
      }
    },
    "generated_files": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/sha256"
      }
    },
    "generated_file_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "redactions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "file_provenance": {
      "type": "object",
      "required": ["path", "hash"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": true
    },
    "plugin_stage": {
      "enum": [
        "observer",
        "trace_source",
        "enricher",
        "verify",
        "render"
      ]
    },
    "plugin_entrypoint": {
      "type": "object",
      "required": ["declared", "resolved", "hashes"],
      "properties": {
        "declared": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resolved": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hashes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["index", "path", "hash"],
            "properties": {
              "index": {
                "type": "integer",
                "minimum": 0
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "hash": {
                "$ref": "#/$defs/sha256"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "observation_run_provenance": {
      "type": "object",
      "required": [
        "schema_version",
        "stage",
        "candidate_rows_hash",
        "accepted_rows_hash",
        "rows_emitted",
        "rows_accepted"
      ],
      "properties": {
        "schema_version": {
          "const": "logicpearl.observation_run_provenance.v1"
        },
        "stage": {
          "$ref": "#/$defs/plugin_stage"
        },
        "plugin_run_id": {
          "$ref": "#/$defs/sha256"
        },
        "observation_schema_hash": {
          "$ref": "#/$defs/sha256"
        },
        "candidate_rows_hash": {
          "$ref": "#/$defs/sha256"
        },
        "accepted_rows_hash": {
          "$ref": "#/$defs/sha256"
        },
        "rows_emitted": {
          "type": "integer",
          "minimum": 0
        },
        "rows_accepted": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "timeout_policy": {
      "type": "object",
      "required": [
        "manifest_timeout_ms",
        "default_timeout_ms",
        "effective_timeout_ms",
        "allow_no_timeout"
      ],
      "properties": {
        "manifest_timeout_ms": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "default_timeout_ms": {
          "type": "integer",
          "minimum": 0
        },
        "effective_timeout_ms": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "allow_no_timeout": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "execution_policy": {
      "type": "object",
      "required": [
        "allow_absolute_entrypoint",
        "allow_path_lookup",
        "allow_no_timeout"
      ],
      "properties": {
        "allow_absolute_entrypoint": {
          "type": "boolean"
        },
        "allow_path_lookup": {
          "type": "boolean"
        },
        "allow_no_timeout": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "capabilities": {
      "type": "object",
      "required": ["declared", "allowed", "enforced"],
      "properties": {
        "declared": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "enforced": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "plugin_access": {
      "type": "object",
      "required": ["network", "filesystem", "enforcement"],
      "properties": {
        "network": {
          "type": "string",
          "minLength": 1
        },
        "filesystem": {
          "type": "string",
          "minLength": 1
        },
        "enforcement": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "plugin_stdio": {
      "type": "object",
      "required": [
        "stdout_hash",
        "stdout_bytes",
        "stderr_hash",
        "stderr_bytes"
      ],
      "properties": {
        "stdout_hash": {
          "$ref": "#/$defs/sha256"
        },
        "stdout_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "stdout_summary": {
          "type": ["string", "null"]
        },
        "stderr_hash": {
          "$ref": "#/$defs/sha256"
        },
        "stderr_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "stderr_summary": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "source": {
      "type": "object",
      "required": ["source_id", "kind", "title", "data_classification"],
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "retrieved_at": {
          "type": "string",
          "minLength": 1
        },
        "content_hash": {
          "$ref": "#/$defs/sha256"
        },
        "data_classification": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
