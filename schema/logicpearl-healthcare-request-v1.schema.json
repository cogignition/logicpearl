          "title": "Assertion Id",
          "type": "string"
        },
        "cluster_id": {
          "title": "Cluster Id",
          "type": "string"
        },
        "value": {
          "enum": [
            "present",
            "absent",
            "unknown"
          ],
          "title": "Value",
          "type": "string"
        },
        "confidence": {
          "title": "Confidence",
          "type": "number"
        },
        "source_document_id": {
          "title": "Source Document Id",
          "type": "string"
        },
        "source_snippet": {
          "title": "Source Snippet",
          "type": "string"
        },
        "citation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Citation"
        },
        "extractor": {
          "title": "Extractor",
          "type": "string"
