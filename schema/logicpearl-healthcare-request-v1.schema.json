        "event_type": {
          "$ref": "#/$defs/ClinicalEventType"
        },
        "code": {
          "title": "Code",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "source": {
          "title": "Source",
          "type": "string"
