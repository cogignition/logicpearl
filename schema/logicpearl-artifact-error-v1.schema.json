{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logicpearl.dev/schema/logicpearl-artifact-error-v1.schema.json",
  "title": "LogicPearl Artifact Error v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "engine_version",
    "error_code",
    "message"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "logicpearl.artifact_error.v1"
    },
    "engine_version": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "error_code": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "details": true
  }
}
