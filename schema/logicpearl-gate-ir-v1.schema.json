{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logicpearl.com/schema/logicpearl-gate-ir-v1.schema.json",
  "title": "LogicPearl Gate IR v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ir_version",
    "gate_id",
    "gate_type",
    "input_schema",
    "rules",
    "evaluation"
  ],
  "properties": {
    "ir_version": {
      "type": "string",
      "const": "1.0"
    },
    "gate_id": {
      "type": "string",
      "minLength": 1
    },
    "gate_type": {
      "type": "string",
      "const": "bitmask_gate"
    },
    "input_schema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["features"],
      "properties": {
        "features": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/feature"
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["combine", "allow_when_bitmask"],
      "properties": {
        "combine": {
          "type": "string",
          "const": "bitwise_or"
        },
        "allow_when_bitmask": {
          "type": "integer",
          "const": 0
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "domain_constraints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/comparison"
          }
        },
        "correctness_scope": {
          "type": "string"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "generator": { "type": "string" },
        "generator_version": { "type": "string" },
        "source_commit": { "type": "string" },
        "created_at": { "type": "string" }
      }
    }
  },
  "$defs": {
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["bool", "int", "float", "string", "enum"]
        },
        "description": {
          "type": "string"
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": ["string", "number", "integer", "boolean"]
          }
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "editable": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": { "const": "enum" }
            }
          },
          "then": {
            "required": ["values"]
          }
        }
      ]
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "bit", "deny_when"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["predicate", "threshold", "weighted_sum"]
        },
        "bit": {
          "type": "integer",
          "minimum": 0
        },
        "deny_when": {
          "$ref": "#/$defs/expression"
        },
        "label": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "counterfactual_hint": {
          "type": "string"
        },
        "verification_status": {
          "type": ["string", "null"],
          "enum": [
            "solver_verified",
            "pipeline_unverified",
            "heuristic_unverified",
            "refined_unverified",
            null
          ]
        },
        "evidence": {
          "$ref": "#/$defs/rule_evidence"
        }
      }
    },
    "rule_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "support"],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "logicpearl.rule_evidence.v1"
        },
        "support": {
          "$ref": "#/$defs/rule_support_evidence"
        },
        "simplifications": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rule_simplification_evidence"
          }
        }
      }
    },
    "rule_simplification_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "reason",
        "before_rule_count",
        "after_rule_count",
        "removed_rule_count",
        "training_total_errors_before",
        "training_total_errors_after",
        "validation_total_errors_before",
        "validation_total_errors_after",
        "denied_trace_count_before",
        "denied_trace_count_after",
        "allowed_trace_count_before",
        "allowed_trace_count_after"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "dropped_predicates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "before_rule_count": {
          "type": "integer",
          "minimum": 0
        },
        "after_rule_count": {
          "type": "integer",
          "minimum": 0
        },
        "removed_rule_count": {
          "type": "integer",
          "minimum": 0
        },
        "training_total_errors_before": {
          "type": "integer",
          "minimum": 0
        },
        "training_total_errors_after": {
          "type": "integer",
          "minimum": 0
        },
        "validation_total_errors_before": {
          "type": "integer",
          "minimum": 0
        },
        "validation_total_errors_after": {
          "type": "integer",
          "minimum": 0
        },
        "denied_trace_count_before": {
          "type": "integer",
          "minimum": 0
        },
        "denied_trace_count_after": {
          "type": "integer",
          "minimum": 0
        },
        "allowed_trace_count_before": {
          "type": "integer",
          "minimum": 0
        },
        "allowed_trace_count_after": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "rule_support_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["denied_trace_count", "allowed_trace_count"],
      "properties": {
        "denied_trace_count": {
          "type": "integer",
          "minimum": 0
        },
        "allowed_trace_count": {
          "type": "integer",
          "minimum": 0
        },
        "example_traces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rule_trace_evidence"
          }
        }
      }
    },
    "rule_trace_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_row_hash"],
      "properties": {
        "trace_row_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "source_anchor": {
          "type": "string",
          "minLength": 1
        },
        "citation": {
          "type": "string",
          "minLength": 1
        },
        "quote_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature", "op", "value"],
      "properties": {
        "feature": {
          "type": "string",
          "minLength": 1
        },
        "op": {
          "type": "string",
          "enum": ["==", "!=", ">", ">=", "<", "<=", "in", "not_in"]
        },
        "value": {}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "op": { "enum": ["in", "not_in"] }
            }
          },
          "then": {
            "properties": {
              "value": {
                "type": "array"
              }
            }
          }
        }
      ]
    },
    "expression": {
      "oneOf": [
        { "$ref": "#/$defs/comparison" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["all"],
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["any"],
          "properties": {
            "any": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["not"],
          "properties": {
            "not": {
              "$ref": "#/$defs/expression"
            }
          }
        }
      ]
    }
  }
}
