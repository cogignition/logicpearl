{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logicpearl.com/schema/logicpearl-demo-manifest-v1.schema.json",
  "title": "LogicPearl Demo Manifest v1",
  "type": "object",
  "required": [
    "demo_id",
    "title",
    "subtitle",
    "tagline",
    "theme",
    "summary",
    "stats",
    "sources",
    "artifacts",
    "cases"
  ],
  "properties": {
    "demo_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "subtitle": {
      "type": "string",
      "minLength": 1
    },
    "tagline": {
      "type": "string",
      "minLength": 1
    },
    "audience": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "theme": {
      "type": "object",
      "required": [
        "name",
        "accent",
        "surface",
        "surface_alt",
        "text",
        "muted"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "accent": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "type": "string",
          "minLength": 1
        },
        "surface_alt": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "muted": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "problem",
        "why_logicpearl",
        "scope",
        "non_goals"
      ],
      "properties": {
        "problem": {
          "type": "string",
          "minLength": 1
        },
        "why_logicpearl": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "stats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "value"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "kind",
          "publisher"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "publisher": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": [
              "string",
              "null"
            ]
          },
          "note": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_updated": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "kind",
          "path"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_id",
          "title",
          "result",
          "summary"
        ],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "bitmask": {
            "type": [
              "integer",
              "null"
            ]
          },
          "failed_requirements": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "requirements": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": false
}
