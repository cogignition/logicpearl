{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logicpearl.com/schema/logicpearl-fanout-pipeline-v1.schema.json",
  "title": "LogicPearl Fan-out Pipeline v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pipeline_id", "actions"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "logicpearl.fanout_pipeline.v1"
    },
    "pipeline_id": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "type": "object",
      "additionalProperties": true
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "artifact"],
        "properties": {
          "action": {
            "type": "string",
            "minLength": 1
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "artifact": {
            "type": "string",
            "minLength": 1
          },
          "input": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
